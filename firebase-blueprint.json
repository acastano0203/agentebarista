{
  "entities": {
    "Coffee": {
      "title": "Coffee",
      "description": "A coffee product available in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the coffee blend or origin." },
        "description": { "type": "string", "description": "Detailed description of the coffee." },
        "roastLevel": { "type": "string", "enum": ["Light", "Medium", "Dark"], "description": "The roast level of the beans." },
        "notes": { "type": "array", "items": { "type": "string" }, "description": "Flavor notes (e.g., chocolate, fruity)." },
        "price": { "type": "number", "description": "Price per bag." },
        "imageUrl": { "type": "string", "description": "URL to the product image." },
        "origin": { "type": "string", "description": "Country or region of origin." },
        "stock": { "type": "integer", "description": "Available inventory." }
      },
      "required": ["name", "price", "roastLevel"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["email", "role"]
    },
    "CoffeeProfile": {
      "title": "Coffee Profile",
      "description": "A user's coffee preference profile generated by the AI Barista.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "preferredNotes": { "type": "array", "items": { "type": "string" } },
        "acidity": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "body": { "type": "string", "enum": ["Light", "Medium", "Full"] },
        "summary": { "type": "string", "description": "AI generated summary of the user's taste." }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "/coffees": {
      "schema": "Coffee",
      "description": "Collection of coffee products."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/profiles/{profileId}": {
      "schema": "CoffeeProfile",
      "description": "Stored coffee preference profiles."
    }
  }
}
